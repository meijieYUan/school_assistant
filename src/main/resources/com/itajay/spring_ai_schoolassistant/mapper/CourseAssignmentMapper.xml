<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.itajay.spring_ai_schoolassistant.mapper.CourseAssignmentMapper">

    <resultMap id="BaseResultMap" type="com.itajay.spring_ai_schoolassistant.entity.po.CourseAssignment">
            <id property="id" column="id" />
            <result property="courseId" column="course_id" />
            <result property="title" column="title" />
            <result property="description" column="description" />
            <result property="deadline" column="deadline" />
            <result property="status" column="status" />
            <result property="createTime" column="create_time" />
            <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="AssignmentView_Column_List">
        c.course_name AS courseName,
        a.title       AS title,
        a.description AS description,
        a.deadline    AS deadline,
        a.status      AS status
    </sql>

    <select id="queryAssignmentsByCourseName"
            resultType="com.itajay.spring_ai_schoolassistant.entity.vo.AssignmentView">
        select
           <include refid="AssignmentView_Column_List"/>
        from course_assignment a
        right join course c on c.id=a.course_id
        where c.course_name=#{courseName};
    </select>
    <select id="queryFinishedAssignments"
            resultType="com.itajay.spring_ai_schoolassistant.entity.vo.AssignmentView">
        select
            <include refid="AssignmentView_Column_List"/>
            from course_assignment a
            right join course c on a.course_id=c.id
        where status=1;
    </select>

    <select id="queryPendingAssignments"
            resultType="com.itajay.spring_ai_schoolassistant.entity.vo.AssignmentView">
        select
        <include refid="AssignmentView_Column_List"/>
        from course_assignment a
        right join course c on a.course_id=c.id
        where status=0;
    </select>

    <select id="queryOverdueAssignments"
            resultType="com.itajay.spring_ai_schoolassistant.entity.vo.AssignmentView">
        select
        <include refid="AssignmentView_Column_List"/>
        from course_assignment a
        right join course c on a.course_id=c.id
        where status=2;
    </select>
</mapper>
